# OpenAI
OPENAI_API_KEY=your_openai_api_key

# Supabase PostgreSQL (Prisma)
# Pooled connection — API runtime (port 6543, pgbouncer)
DATABASE_URL="postgresql://postgres.[PROJECT_REF]:[YOUR-PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true"
# Direct connection — migrations only (port 5432)
DIRECT_URL="postgresql://postgres.[PROJECT_REF]:[YOUR-PASSWORD]@aws-0-[REGION].pooler.supabase.com:5432/postgres"

# Local Postgres alternative (docker compose postgres service)
# DATABASE_URL=postgresql://stamped:stamped_dev_password@localhost:5432/stamped_intelligence
# DIRECT_URL=postgresql://stamped:stamped_dev_password@localhost:5432/stamped_intelligence

# -----------------------------------------------------------------------------
# Qdrant — Qdrant Cloud (recommended; free tier ~1 GB)
# From Cloud Console → Cluster → Connect: copy "Cluster URL" and create an API key.
# -----------------------------------------------------------------------------
QDRANT_URL=https://xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx.region.gcp.cloud.qdrant.io:6333
QDRANT_API_KEY=your_qdrant_cloud_api_key
QDRANT_COLLECTION=stamped_chunks

# -----------------------------------------------------------------------------
# Qdrant — local Docker (optional; only if NOT using Cloud)
# Comment out QDRANT_URL and QDRANT_API_KEY above, then run: docker compose --profile local-qdrant up qdrant -d
# -----------------------------------------------------------------------------
# QDRANT_HOST=localhost
# QDRANT_PORT=6333
# QDRANT_COLLECTION=stamped_chunks

# Batch ingest — comma-separated folders the API may scan (server paths)
INGEST_BATCH_ROOTS=D:\Startups\Stamped\docs

# API — shared secret for ingest routes (web + Discord bot must send the same value)
API_PORT=8000
API_SECRET_KEY=your_secret_key_for_internal_auth
# Comma-separated; defaults in code also allow localhost + https://intelligence-layer.vercel.app
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001,https://intelligence-layer.vercel.app

# Frontend — must match API_SECRET_KEY exactly (required for Ingest page / job list)
NEXT_PUBLIC_API_URL=http://localhost:8000
# Production (Vercel): https://intelligence-layer.onrender.com — see apps/web/.env.production
NEXT_PUBLIC_API_SECRET_KEY=your_secret_key_for_internal_auth

# Discord ingest bot (apps/discord-bot)
DISCORD_BOT_TOKEN=your_discord_bot_token
DISCORD_CLIENT_ID=your_discord_application_id
DISCORD_GUILD_ID=your_dev_guild_id_for_fast_command_registration
DISCORD_COMMAND_ROLE_IDS=
INTELLIGENCE_API_URL=http://localhost:8000
DISCORD_POLL_INTERVAL_HOURS=6
# Message Content Intent must be ON in Discord Developer Portal (required for backfill/poll)
DISCORD_LIVE_INGEST=false
DISCORD_MIN_MESSAGE_CHARS=20
DISCORD_MAX_ATTACHMENT_MB=25
DISCORD_BOT_PORT=3001

# Processing
EMBEDDING_MODEL=text-embedding-3-small
STANDARD_MODEL=gpt-4o-mini
STRATEGIC_MODEL=gpt-4o
MAX_TOKENS_ANSWER=2048
CHUNK_SIZE=512
CHUNK_OVERLAP=64
