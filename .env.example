# OpenAI
OPENAI_API_KEY=your_openai_api_key

# Supabase PostgreSQL (Prisma)
# Pooled connection — API runtime (port 6543, pgbouncer)
DATABASE_URL="postgresql://postgres.[PROJECT_REF]:[YOUR-PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true"
# Direct connection — migrations only (port 5432)
DIRECT_URL="postgresql://postgres.[PROJECT_REF]:[YOUR-PASSWORD]@aws-0-[REGION].pooler.supabase.com:5432/postgres"

# Local Postgres alternative (docker compose postgres service)
# DATABASE_URL=postgresql://stamped:stamped_dev_password@localhost:5432/stamped_intelligence
# DIRECT_URL=postgresql://stamped:stamped_dev_password@localhost:5432/stamped_intelligence

# Qdrant
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_COLLECTION=stamped_chunks

# API
API_PORT=8000
API_SECRET_KEY=your_secret_key_for_internal_auth
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000

# Processing
EMBEDDING_MODEL=text-embedding-3-small
STANDARD_MODEL=gpt-4o-mini
STRATEGIC_MODEL=gpt-4o
MAX_TOKENS_ANSWER=2048
CHUNK_SIZE=512
CHUNK_OVERLAP=64
