{
  "name": "stamped-intelligence",
  "private": true,
  "scripts": {
    "dev": "pnpm --parallel --filter @stamped/api --filter @stamped/web --filter @stamped/discord-bot run dev",
    "dev:api": "pnpm --filter @stamped/api dev",
    "dev:web": "pnpm --filter @stamped/web dev",
    "dev:bot": "pnpm --filter @stamped/discord-bot dev",
    "discord:register": "pnpm --filter @stamped/discord-bot register-commands",
    "build": "pnpm -r run build",
    "start:render": "node scripts/start-render.mjs",
    "db:generate": "pnpm --filter @stamped/database generate",
    "db:migrate": "pnpm --filter @stamped/database migrate:dev",
    "db:migrate:deploy": "pnpm --filter @stamped/database migrate:deploy",
    "db:push": "pnpm --filter @stamped/database push"
  },
  "engines": {
    "node": ">=20 <23"
  },
  "packageManager": "pnpm@9.15.0"
}
