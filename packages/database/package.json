{
  "name": "@stamped/database",
  "version": "0.1.0",
  "private": true,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "postinstall": "dotenv -e ../../.env.local -e ../../.env -- prisma generate",
    "generate": "dotenv -e ../../.env.local -e ../../.env -- prisma generate",
    "migrate:dev": "dotenv -e ../../.env.local -e ../../.env -- prisma migrate dev",
    "migrate:deploy": "dotenv -e ../../.env.local -e ../../.env -- prisma migrate deploy",
    "push": "dotenv -e ../../.env.local -e ../../.env -- prisma db push",
    "studio": "dotenv -e ../../.env.local -e ../../.env -- prisma studio"
  },
  "dependencies": {
    "@prisma/client": "^6.1.0"
  },
  "devDependencies": {
    "dotenv-cli": "^7.4.4",
    "prisma": "^6.1.0",
    "typescript": "^5.7.2"
  }
}
