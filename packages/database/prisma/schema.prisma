generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Document {
  id               String   @id @default(uuid()) @db.Uuid
  sourceType       String   @map("source_type") @db.VarChar(50)
  sourceId         String?  @map("source_id") @db.VarChar(255)
  title            String?
  author           String?  @db.VarChar(255)
  channel          String?  @db.VarChar(255)
  url              String?
  contentHash      String?  @map("content_hash") @db.VarChar(64)
  rawContent       String?  @map("raw_content")
  summary          String?
  tags             String[] @default([])
  wordCount        Int?     @map("word_count")
  ingestedAt       DateTime @default(now()) @map("ingested_at")
  updatedAt        DateTime @updatedAt @map("updated_at")
  ingestionStatus  String   @default("pending") @map("ingestion_status") @db.VarChar(20)
  metadata         Json     @default("{}")

  chunks          Chunk[]
  entityMentions  EntityMention[]

  @@index([sourceType])
  @@index([ingestedAt(sort: Desc)])
  @@map("documents")
}

model Chunk {
  id          String   @id @default(uuid()) @db.Uuid
  documentId  String   @map("document_id") @db.Uuid
  chunkIndex  Int      @map("chunk_index")
  chunkText   String   @map("chunk_text")
  embeddingId String?  @map("embedding_id") @db.VarChar(255)
  tokenCount  Int?     @map("token_count")
  metadata    Json     @default("{}")
  createdAt   DateTime @default(now()) @map("created_at")

  document        Document         @relation(fields: [documentId], references: [id], onDelete: Cascade)
  entityMentions  EntityMention[]
  relationshipEvidence Relationship[] @relation("EvidenceChunk")

  @@index([documentId])
  @@map("chunks")
}

model Entity {
  id           String   @id @default(uuid()) @db.Uuid
  name         String   @db.VarChar(255)
  entityType   String   @map("entity_type") @db.VarChar(100)
  description  String?
  aliases      String[] @default([])
  graphNodeId  String?  @map("graph_node_id") @db.VarChar(255)
  mentionCount Int      @default(1) @map("mention_count")
  firstSeenAt  DateTime @default(now()) @map("first_seen_at")
  lastSeenAt   DateTime @default(now()) @map("last_seen_at")
  metadata     Json     @default("{}")

  mentions            EntityMention[]
  relationshipsFrom   Relationship[] @relation("SourceEntity")
  relationshipsTo     Relationship[] @relation("TargetEntity")

  @@map("entities")
}

model EntityMention {
  id             String   @id @default(uuid()) @db.Uuid
  entityId       String   @map("entity_id") @db.Uuid
  chunkId        String   @map("chunk_id") @db.Uuid
  documentId     String   @map("document_id") @db.Uuid
  contextSnippet String?  @map("context_snippet")
  confidence     Float    @default(1.0)
  createdAt      DateTime @default(now()) @map("created_at")

  entity   Entity   @relation(fields: [entityId], references: [id], onDelete: Cascade)
  chunk    Chunk    @relation(fields: [chunkId], references: [id], onDelete: Cascade)
  document Document @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@unique([entityId, chunkId])
  @@index([entityId])
  @@map("entity_mentions")
}

model Relationship {
  id               String   @id @default(uuid()) @db.Uuid
  sourceEntityId   String   @map("source_entity_id") @db.Uuid
  targetEntityId   String   @map("target_entity_id") @db.Uuid
  relationshipType String?  @map("relationship_type") @db.VarChar(100)
  confidence       Float    @default(1.0)
  evidenceChunkId  String?  @map("evidence_chunk_id") @db.Uuid
  createdAt        DateTime @default(now()) @map("created_at")

  sourceEntity  Entity @relation("SourceEntity", fields: [sourceEntityId], references: [id])
  targetEntity  Entity @relation("TargetEntity", fields: [targetEntityId], references: [id])
  evidenceChunk Chunk? @relation("EvidenceChunk", fields: [evidenceChunkId], references: [id])

  @@map("relationships")
}

model Conversation {
  id        String   @id @default(uuid()) @db.Uuid
  sessionId String   @map("session_id") @db.VarChar(255)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  metadata  Json     @default("{}")

  messages Message[]

  @@map("conversations")
}

model Message {
  id                    String   @id @default(uuid()) @db.Uuid
  conversationId        String   @map("conversation_id") @db.Uuid
  role                  String   @db.VarChar(20)
  content               String
  retrievedChunkIds     String[] @default([]) @map("retrieved_chunk_ids") @db.Uuid
  retrievedDocumentIds  String[] @default([]) @map("retrieved_document_ids") @db.Uuid
  modelUsed             String?  @map("model_used") @db.VarChar(100)
  createdAt             DateTime @default(now()) @map("created_at")

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId])
  @@map("messages")
}

model IngestionJob {
  id             String    @id @default(uuid()) @db.Uuid
  jobType        String    @map("job_type") @db.VarChar(50)
  status         String    @default("queued") @db.VarChar(20)
  totalItems     Int?      @map("total_items")
  processedItems Int       @default(0) @map("processed_items")
  failedItems    Int       @default(0) @map("failed_items")
  errorLog       String?   @map("error_log")
  startedAt      DateTime? @map("started_at")
  completedAt    DateTime? @map("completed_at")
  createdAt      DateTime  @default(now()) @map("created_at")
  metadata       Json      @default("{}")

  @@map("ingestion_jobs")
}

model DiscordChannelSubscription {
  id          String   @id @default(uuid()) @db.Uuid
  guildId     String   @map("guild_id") @db.VarChar(32)
  channelId   String   @unique @map("channel_id") @db.VarChar(32)
  channelName String?  @map("channel_name") @db.VarChar(255)
  enabled     Boolean  @default(true)
  enabledBy   String?  @map("enabled_by") @db.VarChar(32)
  enabledAt   DateTime @default(now()) @map("enabled_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@index([guildId])
  @@map("discord_channel_subscriptions")
}

model DiscordIngestCursor {
  channelId        String    @id @map("channel_id") @db.VarChar(32)
  lastMessageId    String?   @map("last_message_id") @db.VarChar(32)
  lastPollAt       DateTime? @map("last_poll_at")
  lastBackfillAt   DateTime? @map("last_backfill_at")
  lastLiveIngestAt DateTime? @map("last_live_ingest_at")

  @@map("discord_ingest_cursors")
}

/// Single-row runtime AI model configuration (editable from Admin UI).
model SystemConfig {
  id             String   @id @default("default") @db.VarChar(32)
  standardModel  String   @default("gpt-4o-mini") @map("standard_model") @db.VarChar(100)
  strategicModel String   @default("gpt-4o") @map("strategic_model") @db.VarChar(100)
  embeddingModel String   @default("text-embedding-3-small") @map("embedding_model") @db.VarChar(100)
  updatedAt      DateTime @updatedAt @map("updated_at")

  @@map("system_config")
}
